      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/domain-model",
              "concepts/agent-operating-model",
              "concepts/approval-policy",
              "concepts/skills-standard",
              "concepts/runtime-and-queue"
            ]
          },
          {
            "group": "Modules",
            "pages": [
              "modules/chat",
              "modules/agents",
              "modules/knowledge",
              "modules/projects",
              "modules/tasks",
              "modules/inbox",
              "modules/audit-log",
              "modules/budget",
              "modules/skills",
              "modules/tools",
              "modules/plugins",
              "modules/automation",
              "modules/providers",
              "modules/settings",
              "modules/auth",
              "modules/engine"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/configuration",
              "guides/coding-rules",
              "guides/prompt-playbook",
              "guides/contributing"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/health",
              "api-reference/auth-token"
            ]
          },
          {
            "group": "Knowledge API",
            "pages": [
              "api-reference/knowledge/commands",
              "api-reference/knowledge/converter-status",
              "api-reference/knowledge/list-documents",
              "api-reference/knowledge/upload-document",
              "api-reference/knowledge/index-document",
              "api-reference/knowledge/list-chunks",
              "api-reference/knowledge/delete-document",
              "api-reference/knowledge/retrieve"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/omaicode/familyco",
          "icon": "github"
        },
        {
          "anchor": "Releases",
          "href": "https://github.com/omaicode/familyco/releases",
          "icon": "download"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/omaicode/familyco"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://github.com/omaicode/familyco/releases"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/omaicode/familyco"
    }
  }
}
